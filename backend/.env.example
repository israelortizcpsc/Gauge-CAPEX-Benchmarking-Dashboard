# Copy to .env and adjust for your environment. Loaded by your shell / host;
# settings.py reads these via os.environ.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed to call the API (production).
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Postgres in production, e.g. postgres://user:pass@host:5432/dbname
# DATABASE_URL=
